# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables
# Add for Production, Preview, and/or Development as needed.

ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=use-a-long-random-password

# Passwords with $ : in Vercel dashboard paste the literal password; do not use shell escaping.
# Optional: if local .env parsing is wrong, rely on Vercel env vars only in production.

# --- Vercel: Redis for publish/delete (pick ONE style) ---
#
# A) Vercel Storage → Redis quickstart (node-redis + TCP):
#    REDIS_URL=redis://default:...@...:port
#    If you set a custom env prefix in the integration (e.g. STORAGE), the
#    variable may be STORAGE_URL instead — the app checks REDIS_URL then STORAGE_URL.
#
# B) Upstash REST (also used by some Vercel / legacy KV setups):
#    UPSTASH_REDIS_REST_URL=
#    UPSTASH_REDIS_REST_TOKEN=
#    or KV_REST_API_URL + KV_REST_API_TOKEN
#
# Without Redis configured on Vercel, publish/delete/type-create will fail.
# Local dev can omit these; the app uses ./data and ./posts on disk.
