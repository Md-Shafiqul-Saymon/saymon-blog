# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables
# Add for Production, Preview, and/or Development as needed.

ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=use-a-long-random-password

# Passwords with $ : in Vercel dashboard paste the literal password; do not use shell escaping.
# Optional: if local .env parsing is wrong, rely on Vercel env vars only in production.

# --- Vercel note ---
# Deployed functions use a read-only filesystem (except /tmp, which is ephemeral).
# Publish/delete and writing under /posts or /data will not persist across requests on Vercel
# unless you move storage to a database, Vercel Blob, KV, etc. Static content in the repo
# (e.g. committed data/posts.json) is served as shipped at build time.
